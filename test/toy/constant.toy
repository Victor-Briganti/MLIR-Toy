# RUN: toy-compiler %s --emit=mlir-toy 2>&1 | FileCheck %s

# CHECK-LABEL: toy.func @main()
def main() {
  # CHECK: %[[CONST0:.*]] = toy.constant dense<1.000000e+00> : tensor<f64>
  var a = 1;

  # CHECK: %[[CONST1:.*]] = toy.constant dense<{{\[\[.*\]\]}}> : tensor<2x3xf64>
  # CHECK: %[[RESHAPE:.*]] = toy.reshape(%[[CONST1]] : tensor<2x3xf64>) to tensor<2x3xf64>
  var b<2, 3> = [[1, 2, 3], [4, 5, 6]];
  
  # CHECK: toy.print %[[CONST0]] : tensor<f64>
  print(a);
  # CHECK: toy.return
}
